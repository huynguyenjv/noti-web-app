<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ============ Đầu trang ============ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:textAllCaps="true"
            android:letterSpacing="0.18"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:text="Noti Test" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="16dp"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:text="Bảng đo pipeline notification" />

        <!-- ============ SIGNATURE: thanh pipeline — sáng dần theo trạng thái thật ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/stepToken"
                style="@style/SectionLabel"
                android:background="@drawable/bg_step_idle"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Token" />

            <View
                android:id="@+id/railA"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                android:layout_marginHorizontal="6dp"
                android:background="@color/border" />

            <TextView
                android:id="@+id/stepRegistered"
                style="@style/SectionLabel"
                android:background="@drawable/bg_step_idle"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Đã đăng ký" />

            <View
                android:id="@+id/railB"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                android:layout_marginHorizontal="6dp"
                android:background="@color/border" />

            <TextView
                android:id="@+id/stepRealtime"
                style="@style/SectionLabel"
                android:background="@drawable/bg_step_idle"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Realtime" />
        </LinearLayout>

        <!-- ============ Kết nối ============ -->
        <com.google.android.material.card.MaterialCardView style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SectionLabel"
                    android:text="Kết nối" />

                <TextView
                    style="@style/FieldLabel"
                    android:text="Notification service URL" />

                <EditText
                    android:id="@+id/backendUrl"
                    style="@style/Input"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:inputType="textUri"
                    android:hint="https://notification.example.com"
                    android:text="@string/default_service_url" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_faint"
                    android:text="App gọi thẳng /api/v1/* của service — không cần dựng web server." />

                <TextView
                    style="@style/FieldLabel"
                    android:text="User ID" />

                <EditText
                    android:id="@+id/userIdInput"
                    style="@style/Input"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:hint="demo-user"
                    android:text="demo-user" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_faint"
                    android:text="Dùng chung cho đăng ký, gửi, hộp thư và realtime." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ Thiết bị ============ -->
        <com.google.android.material.card.MaterialCardView style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SectionLabel"
                    android:text="Thiết bị" />

                <TextView
                    style="@style/FieldLabel"
                    android:text="FCM device token" />

                <TextView
                    android:id="@+id/tokenText"
                    style="@style/Mono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textIsSelectable="true"
                    android:text="đang lấy token…" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyButton"
                        style="@style/BtnQuiet"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Copy token" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/registerButton"
                        style="@style/Btn"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Đăng ký device" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ Realtime ============ -->
        <com.google.android.material.card.MaterialCardView style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SectionLabel"
                    android:text="Realtime" />

                <TextView
                    android:id="@+id/rtStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:text="Offline. OUTAPP sẽ đến bằng push." />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rtButton"
                    style="@style/BtnQuiet"
                    android:layout_width="match_parent"
                    android:layout_marginTop="12dp"
                    android:text="Bật realtime" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ Gửi ============ -->
        <com.google.android.material.card.MaterialCardView style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SectionLabel"
                    android:text="Gửi qua notification service" />

                <TextView
                    style="@style/FieldLabel"
                    android:text="Người nhận" />

                <EditText
                    android:id="@+id/recipientInput"
                    style="@style/Input"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:hint="mặc định = User ID ở trên" />

                <TextView
                    style="@style/FieldLabel"
                    android:text="Channels" />

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="false"
                    app:chipSpacingVertical="0dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chPush"
                        style="@style/ChannelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="PUSH" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chInapp"
                        style="@style/ChannelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INAPP" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chEmail"
                        style="@style/ChannelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMAIL" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chSms"
                        style="@style/ChannelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SMS" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chZalo"
                        style="@style/ChannelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ZALO_ZNS" />
                </com.google.android.material.chip.ChipGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/FieldLabel"
                            android:text="Type" />

                        <EditText
                            android:id="@+id/typeInput"
                            style="@style/Input"
                            android:fontFamily="monospace"
                            android:textSize="12sp"
                            android:inputType="textCapCharacters"
                            android:text="BOOKING_CONFIRMED" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/FieldLabel"
                            android:text="Template" />

                        <EditText
                            android:id="@+id/templateInput"
                            style="@style/Input"
                            android:fontFamily="monospace"
                            android:textSize="12sp"
                            android:inputType="text"
                            android:text="booking_confirmed" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/FieldLabel"
                            android:text="Locale" />

                        <Spinner
                            android:id="@+id/localeSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:paddingVertical="6dp"
                            android:entries="@array/locales" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <TextView
                            style="@style/FieldLabel"
                            android:text="Priority" />

                        <Spinner
                            android:id="@+id/prioritySpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:paddingVertical="6dp"
                            android:entries="@array/priorities" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/FieldLabel"
                    android:text="Event ref — để trống thì server tự sinh" />

                <EditText
                    android:id="@+id/eventRefInput"
                    style="@style/Input"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:inputType="text"
                    android:hint="tự sinh" />

                <TextView
                    style="@style/FieldLabel"
                    android:text="Data (JSON)" />

                <EditText
                    android:id="@+id/dataInput"
                    style="@style/Input"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:gravity="top|start"
                    android:hint="{&quot;key&quot;:&quot;value&quot;}" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    style="@style/Btn"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:text="Gửi notification" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ Hộp thư ============ -->
        <com.google.android.material.card.MaterialCardView style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        style="@style/SectionLabel"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:text="Hộp thư · INAPP" />

                    <TextView
                        android:id="@+id/badgeText"
                        style="@style/SectionLabel"
                        android:background="@drawable/bg_step_idle"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="0 chưa đọc" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/inboxContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/inboxRefreshButton"
                    style="@style/BtnQuiet"
                    android:layout_width="match_parent"
                    android:layout_marginTop="4dp"
                    android:text="Tải hộp thư" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ Log: băng giấy ============ -->
        <com.google.android.material.card.MaterialCardView style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    style="@style/SectionLabel"
                    android:layout_marginBottom="10dp"
                    android:text="Log" />

                <TextView
                    android:id="@+id/logText"
                    style="@style/Mono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="90dp"
                    android:textColor="@color/text_muted"
                    android:text="chờ thao tác đầu tiên…" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
